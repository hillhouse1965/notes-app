# PostgreSQL (Railway Postgres service → Variables → DATABASE_URL)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"

# Auth.js — REQUIRED for sign-in to work
# Use a simple alphanumeric secret (avoid / and = characters which can break some hosts)
# PowerShell: -join ((48..57 + 65..90 + 97..122) | Get-Random -Count 48 | ForEach-Object {[char]$_})
AUTH_SECRET="paste-a-48-character-alphanumeric-string-here"

# Your live app URL — no trailing slash
AUTH_URL="https://notes-app-production-6261.up.railway.app"

# Recommended on Railway
AUTH_TRUST_HOST="true"

# GitHub OAuth App — https://github.com/settings/developers
# Callback URL must be: {AUTH_URL}/api/auth/callback/github
AUTH_GITHUB_ID="your-github-client-id"
AUTH_GITHUB_SECRET="your-github-client-secret"
